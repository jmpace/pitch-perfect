{
  "name": "pitch-perfect",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "node scripts/https-dev-server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:fix": "jest --updateSnapshot --verbose",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:post-task": "playwright test --grep=\"Post-Task Verification\"",
    "test:smoke": "playwright test --grep=\"Critical User Journeys\"",
    "test:all": "npm run test:ci && npm run test:e2e",
    "verify-task": "node scripts/post-task-verification.js",
    "security:monitor": "node scripts/security-monitor.js",
    "security:test": "node scripts/test-https.js",
    "security:audit": "npm audit && npm run security:monitor",
    "cors:test": "node scripts/test-cors.js",
    "cors:verify": "npm run cors:test"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@types/dompurify": "^3.0.5",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/validator": "^13.15.1",
    "@vercel/blob": "^1.1.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.6",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "fast-video-metadata": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "geist": "^1.3.1",
    "isomorphic-dompurify": "^2.25.0",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.1.5",
    "next": "15.3.2",
    "next-themes": "^0.4.6",
    "openai": "^5.0.1",
    "postcss": "^8.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^3.0.2",
    "recharts": "^2.15.0",
    "replicate": "^1.0.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "validator": "^13.15.15"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "https": "^1.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "jest-environment-node": "^30.0.0-beta.3",
    "node-mocks-http": "^1.17.2",
    "ts-jest": "^29.3.4",
    "tw-animate-css": "^1.3.2"
  }

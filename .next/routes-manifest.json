{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/api/storage/video/[videoId]",
      "regex": "^/api/storage/video/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPvideoId": "nxtPvideoId"
      },
      "namedRegex": "^/api/storage/video/(?<nxtPvideoId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/video/optimized-status/[jobId]",
      "regex": "^/api/video/optimized\\-status/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPjobId": "nxtPjobId"
      },
      "namedRegex": "^/api/video/optimized\\-status/(?<nxtPjobId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/video/result/[jobId]",
      "regex": "^/api/video/result/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPjobId": "nxtPjobId"
      },
      "namedRegex": "^/api/video/result/(?<nxtPjobId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/video/status/[jobId]",
      "regex": "^/api/video/status/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPjobId": "nxtPjobId"
      },
      "namedRegex": "^/api/video/status/(?<nxtPjobId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/results/[id]",
      "regex": "^/results/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/results/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/dashboard-demo",
      "regex": "^/dashboard\\-demo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard\\-demo(?:/)?$"
    },
    {
      "page": "/results",
      "regex": "^/results(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/results(?:/)?$"
    },
    {
      "page": "/timeline-demo",
      "regex": "^/timeline\\-demo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/timeline\\-demo(?:/)?$"
    },
    {
      "page": "/timeline-demo-simple",
      "regex": "^/timeline\\-demo\\-simple(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/timeline\\-demo\\-simple(?:/)?$"
    },
    {
      "page": "/upload",
      "regex": "^/upload(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/upload(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}